# ─────────────────────────────────────────
# Environment variables / secrets
# ─────────────────────────────────────────
.env
.env.*
*.env

# ─────────────────────────────────────────
# Python cache files
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ─────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────
venv/
env/
.venv/

# ─────────────────────────────────────────
# Jupyter notebook checkpoints
# ─────────────────────────────────────────
.ipynb_checkpoints/

# ─────────────────────────────────────────
# Streamlit cache
# ─────────────────────────────────────────
.streamlit/

# ─────────────────────────────────────────
# OS files
# ─────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────
# Generated outputs
# (charts, reports, presentations)
# ─────────────────────────────────────────
outputs/*.png
outputs/*.pdf
outputs/*.pptx

# or ignore entire outputs folder
# outputs/

# ─────────────────────────────────────────
# Logs
# ─────────────────────────────────────────
*.log

# ─────────────────────────────────────────
# Node modules (for JS script)
# ─────────────────────────────────────────
node_modules/

# ─────────────────────────────────────────
# Python build files
# ─────────────────────────────────────────
build/
dist/
*.egg-info/

# ─────────────────────────────────────────
# IDE settings
# ─────────────────────────────────────────
.vscode/
.idea/